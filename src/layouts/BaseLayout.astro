---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = "VIPER Security — Luxury Chauffeur & VIP Transport | Marbella & Milano",
  description = "Premium luxury chauffeur service for VIP airport transfers, executive travel, and private transportation in Marbella, Costa del Sol, and Milano. Mercedes S-Class fleet. Book your ride today.",
  ogImage = "https://images.unsplash.com/photo-1549399542-7e3f8b79c341?w=1200&q=80",
  canonicalUrl = "https://vipersecurity.com",
} = Astro.props as Props;

const siteUrl = "https://vipersecurity.com";

import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="VIPER Security" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin fetchpriority="high" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Manrope:wght@300;400;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Manrope:wght@300;400;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "{siteUrl}#organization",
            "name": "VIPER Security",
            "url": "{siteUrl}",
            "logo": "{siteUrl}/favicon.svg",
            "description": "Premium private chauffeur service providing luxury transport, airport transfers, and VIP transportation in Marbella and Milano.",
            "foundingDate": "2024",
            "contactPoint": [
              {
                "@type": "ContactPoint",
                "telephone": "+39-349-663-8171",
                "contactType": "customer service",
                "areaServed": ["IT", "SM", "VA"],
                "availableLanguage": ["English", "Italian"]
              },
              {
                "@type": "ContactPoint",
                "telephone": "+34-670-038-541",
                "contactType": "customer service",
                "areaServed": ["ES"],
                "availableLanguage": ["English", "Spanish"]
              }
            ],
            "sameAs": []
          },
          {
            "@type": "WebSite",
            "@id": "{siteUrl}#website",
            "name": "VIPER Security",
            "url": "{siteUrl}",
            "publisher": { "@id": "{siteUrl}#organization" },
            "inLanguage": "en-GB",
            "potentialAction": {
              "@type": "SearchAction",
              "target": {
                "@type": "EntryPoint",
                "urlTemplate": "{siteUrl}/?q={search_term_string}"
              },
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "LocalBusiness",
            "@id": "{siteUrl}#business",
            "name": "VIPER Security",
            "url": "{siteUrl}",
            "logo": "{siteUrl}/favicon.svg",
            "image": "https://images.unsplash.com/photo-1549399542-7e3f8b79c341?w=1200&q=80",
            "description": "Premium luxury chauffeur service providing VIP airport transfers, executive travel, and private transportation.",
            "telephone": ["+39-349-663-8171", "+34-670-038-541"],
            "priceRange": "€€€€",
            "openingHoursSpecification": {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
              "opens": "00:00",
              "closes": "23:59"
            },
            "areaServed": [
              {
                "@type": "City",
                "name": "Marbella",
                "sameAs": "https://www.wikidata.org/wiki/Q180429"
              },
              {
                "@type": "City",
                "name": "Milano",
                "sameAs": "https://www.wikidata.org/wiki/Q490"
              },
              {
                "@type": "City",
                "name": "Costa del Sol",
                "sameAs": "https://www.wikidata.org/wiki/Q2148160"
              },
              {
                "@type": "City",
                "name": "Puerto Banús"
              }
            ],
            "parentOrganization": { "@id": "{siteUrl}#organization" }
          },
          {
            "@type": "Service",
            "@id": "{siteUrl}#service-airport",
            "name": "Luxury Airport Transfer Service",
            "description": "Premium chauffeur-driven airport transfers from Málaga, Gibraltar, Milano Linate, Malpensa, and Bergamo airports.",
            "provider": { "@id": "{siteUrl}#business" },
            "areaServed": ["Costa del Sol", "Milano", "Swiss Alps", "French Riviera"],
            "serviceType": "Airport Transfer"
          },
          {
            "@type": "Service",
            "@id": "{siteUrl}#service-hourly",
            "name": "Hourly Chauffeur Service",
            "description": "Professional chauffeur service with luxury vehicles available by the hour in Marbella and Milano.",
            "provider": { "@id": "{siteUrl}#business" },
            "areaServed": ["Costa del Sol", "Milano"],
            "serviceType": "Chauffeur Service"
          }
        ]
      }
    </script>
  </head>
  <body class="bg-black text-white font-body">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:bg-gold focus:text-black focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:uppercase focus:tracking-wider focus:font-body focus:font-semibold">
      Skip to main content
    </a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
