    @media (max-width:767px) and (min-width:480px) { html.w-mod-js:not(.w-mod-ix) [data-w-id="e05755dd-04a4-7cdb-2710-9516b4314eb0"] { width:0PX;height:0px; } }
    @media (max-width:479px) { html.w-mod-js:not(.w-mod-ix) [data-w-id="e05755dd-04a4-7cdb-2710-9516b4314eb0"] { width:0PX;height:0px; } }
