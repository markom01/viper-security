---
import STRINGS from '../config/strings';
const s = STRINGS;
const { pageContent } = Astro.props;
const seo = pageContent?.seo;
const siteUrl = Astro.site || new URL('https://vipersecurity.com');
const ogImageUrl = new URL('/images/hero-image.webp', siteUrl);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const jd = s.jsonld;
const jsonLdOrg = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "${jd.orgName}",
  "url": "${jd.orgUrl}",
  "logo": "${jd.orgLogo}",
  "description": "${jd.orgDescription}",
  "address": [
    {"@type": "PostalAddress", "addressLocality": "Marbella", "addressCountry": "ES"},
    {"@type": "PostalAddress", "addressLocality": "Milano", "addressCountry": "IT"}
  ],
  "telephone": ["${jd.phoneSpain}", "${jd.phoneItaly}"]
}
<\/script>`;
const jsonLdWebSite = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "${jd.webSiteName}",
  "url": "${jd.webSiteUrl}"
}
<\/script>`;
---

