  <link href="/template_files/678bb790c580384223c687e8_webclip.png" rel="apple-touch-icon">
  <Fragment set:html={jsonLdOrg} />
  <Fragment set:html={jsonLdWebSite} />
</head>
<body>
  <a href="#main-content" class="skip-link">{s.skipLink}</a>
  <main id="main-content" class="page-wrapper">
    <slot />
  </main>
