<html lang="en" data-wf-page="674324efa61b92a6f6b76bc1">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <style>[tabindex="-1"]:focus-visible{outline:2px solid #C1A176;outline-offset:2px;}:focus-visible{outline:2px solid #C1A176;outline-offset:2px;}.skip-link{position:absolute;top:-100%;left:0;z-index:9999;padding:12px 24px;background:#000;color:#C1A176;font-family:'Work Sans',sans-serif;font-size:1rem;text-decoration:none;}.skip-link:focus{top:0;}</style>
  <link href="https://cdn.prod.website-files.com/" rel="preconnect" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@100;200;300;400;500;600;700;800;900&family=Noto+Serif:wght@100;200;300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  <link href="/template_files/chauffure.webflow.5728f95f4.min.css" rel="preload" as="style" onload="this.rel='stylesheet'"><noscript><link href="/template_files/chauffure.webflow.5728f95f4.min.css" rel="stylesheet"></noscript>
  <title>{seo?.title || s.seo.title}</title>
  <link rel="canonical" href={canonicalUrl}>
  <meta content={seo?.description || s.seo.description} name="description">
  <meta content={seo?.title || s.seo.title} property="og:title">
  <meta content={seo?.description || s.seo.description} property="og:description">
  <meta content={ogImageUrl} property="og:image">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content={s.jsonld.orgName}>
  <meta property="og:locale" content={s.seo.ogLocale}>
  <meta content={seo?.title || s.seo.title} name="twitter:title">
  <meta content={seo?.description || s.seo.description} name="twitter:description">
  <meta content={ogImageUrl} name="twitter:image">
  <meta property="og:type" content={s.seo.ogType}>
  <meta content={s.seo.twitterCard} name="twitter:card">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta name="theme-color" content={seo?.theme_color || s.seo.themeColor}>
  <style>
    @media (min-width:992px) { html.w-mod-js:not(.w-mod-ix) [data-w-id="e05755dd-04a4-7cdb-2710-9516b4314eb0"] { width:0px; } }
