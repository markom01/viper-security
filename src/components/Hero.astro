---
import { getCollection } from 'astro:content';

const [heroEntry] = await getCollection('hero');
const {
  brand_name,
  tagline,
  subtitle,
  cta_text,
  phone_italy,
  phone_spain,
} = heroEntry?.data || {};
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#000000]"
  aria-label="Hero"
>
  <div
    class="absolute inset-0 bg-[var(--gold-gradient-glow)] pointer-events-none"
    aria-hidden="true"
  ></div>

  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>

  <div
    class="relative z-10 w-full max-w-[1440px] mx-auto px-6 lg:px-12 py-24 flex flex-col items-center text-center"
  >
    <p
      class="animate-fade-in text-ash text-[10px] sm:text-xs uppercase tracking-[0.25em] font-body font-light mb-3"
    >
      Private Chauffeur &amp; Luxury Transport
    </p>
    <h1
      class="animate-fade-in font-heading text-gold text-5xl sm:text-6xl md:text-7xl lg:text-8xl tracking-[0.08em] leading-[1.1] mb-5"
    >
      {brand_name || 'VIPER SECURITY'}
    </h1>

    <p
      class="animate-fade-in text-white text-base sm:text-lg md:text-xl lg:text-2xl font-body font-light uppercase tracking-[0.15em] mb-3 max-w-3xl"
    >
      {tagline || 'TRAVEL IN STYLE. ARRIVE IN COMFORT.'}
    </p>

    <p
      class="animate-fade-in text-smoke/60 text-sm sm:text-base md:text-lg font-body font-light mb-10 max-w-xl"
    >
      {subtitle || 'VIP Chauffeur & Luxury Transport — Marbella & Milano'}
    </p>

    <a
      href="#contact"
      class="animate-fade-in inline-block bg-gold text-black text-sm uppercase tracking-[0.12em] font-body font-semibold px-10 py-4 no-underline transition-all duration-300 hover:bg-gold-light hover:shadow-[0_0_30px_-5px_rgba(176,141,69,0.4)]"
    >
      {cta_text || 'BOOK YOUR RIDE'}
    </a>

    <div
      class="animate-fade-in flex flex-wrap justify-center gap-x-8 gap-y-2 mt-10"
    >
      {
        phone_italy && (
          <a
            href={`tel:${phone_italy.replace(/\D/g, '')}`}
            class="text-smoke/50 hover:text-gold text-sm font-body tracking-[0.05em] transition-colors duration-200 no-underline"
          >
            Italy: <span class="text-white/80 hover:text-white">{phone_italy}</span>
          </a>
        )
      }
      {
        phone_spain && (
          <a
            href={`tel:${phone_spain.replace(/\D/g, '')}`}
            class="text-smoke/50 hover:text-gold text-sm font-body tracking-[0.05em] transition-colors duration-200 no-underline"
          >
            Spain: <span class="text-white/80 hover:text-white">{phone_spain}</span>
          </a>
        )
      }
    </div>

    <div
      class="animate-fade-in flex flex-col items-center mt-8"
    >
      <div
        class="text-gold text-lg sm:text-xl tracking-[0.15em] leading-none"
        aria-label="5 star rating"
      >
        ★★★★★
      </div>
      <p
        class="text-white/60 text-[10px] sm:text-xs uppercase tracking-[0.18em] font-body mt-2.5"
      >
        LUXURY • COMFORT • PRIVACY
      </p>
    </div>

    <div
      class="animate-fade-in flex flex-wrap justify-center gap-x-6 gap-y-3 mt-9"
    >
      {
        [
          "Professional Drivers",
          "Punctual",
          "Premium Vehicles",
          "Discreet",
          "24/7 Service",
        ].map((label) => (
          <div class="flex items-center gap-2">
            <span class="block w-1.5 h-1.5 bg-gold flex-shrink-0"></span>
            <span class="text-white/60 text-[10px] sm:text-xs uppercase tracking-[0.1em] font-body font-light whitespace-nowrap">
              {label}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  /* ─── Fade-in up animation ─── */
  @keyframes hero-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: hero-fade-in-up 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    opacity: 0;
  }

  .animate-fade-in:nth-child(1) { animation-delay: 0.05s; }
  .animate-fade-in:nth-child(2) { animation-delay: 0.15s; }
  .animate-fade-in:nth-child(3) { animation-delay: 0.25s; }
  .animate-fade-in:nth-child(4) { animation-delay: 0.35s; }
  .animate-fade-in:nth-child(5) { animation-delay: 0.45s; }
  .animate-fade-in:nth-child(6) { animation-delay: 0.60s; }
  .animate-fade-in:nth-child(7) { animation-delay: 0.75s; }
  .animate-fade-in:nth-child(8) { animation-delay: 0.90s; }
</style>
