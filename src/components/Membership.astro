---
import { getCollection } from 'astro:content';
const [membership] = await getCollection('membership');
const tiers = membership?.data?.tiers || [];
const formatPrice = (price) => {
  if (price == null || (typeof price === 'number' && isNaN(price))) return '\u2014';
  return '\u20AC' + Number(price).toLocaleString('en-US');
};
---

<section id="membership" class="bg-black py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="font-heading text-gold text-4xl md:text-5xl lg:text-6xl tracking-wider">
        VIP MEMBERSHIP
      </h2>
      <div class="w-12 h-0.5 bg-gold/40 mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch">
      {
        tiers.map((tier) => (
          <div
            class={`tier-card relative flex flex-col rounded p-8 ${
              tier.is_featured
                ? "bg-dark-iron border-2 border-gold shadow-[var(--gold-glow-subtle)]"
                : "bg-dark-iron border border-white/10"
            }`}
          >
            {
              tier.is_featured && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold text-black text-[10px] sm:text-xs  font-body font-semibold px-4 py-1">
                  BEST VALUE
                </span>
              )
            }

            <h3 class="font-heading text-white text-xl md:text-2xl tracking-wider mt-2">
              {tier.name}
            </h3>

            <div class="mt-4 mb-6">
              <span class="font-heading text-gold text-4xl md:text-5xl font-bold">
                {formatPrice(tier.price)}
              </span>
              <span class="text-white/50 text-sm font-body ml-1">
                /year
              </span>
            </div>

            <div class="w-full h-px bg-white/5 mb-6"></div>

            <ul class="flex flex-col gap-3 flex-1 mb-8">
              {
                tier.benefits.map((benefit) => (
                  <li class="flex items-start gap-3 text-white/80 text-sm lg:text-base font-body leading-relaxed">
                    <span class="text-gold shrink-0 mt-0.5">✦</span>
                    {benefit}
                  </li>
                ))
              }
            </ul>

            <a
              href="#contact"
              class={`block text-center text-sm font-body font-semibold px-6 py-3.5 no-underline transition-all duration-200 mt-auto ${
                tier.is_featured
                  ? "bg-gold text-black hover:bg-gold-light"
                  : "bg-transparent border border-gold text-gold hover:bg-gold hover:text-black"
              }`}
            >
              REQUEST BOOKING
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tier-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s cubic-bezier(0.25, 1, 0.5, 1), transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .tier-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .tier-card:nth-child(1) { transition-delay: 0ms; }
  .tier-card:nth-child(2) { transition-delay: 100ms; }
  .tier-card:nth-child(3) { transition-delay: 200ms; }
</style>

<script>
  (function () {
    var cards = document.querySelectorAll("#membership .tier-card");
    if (!cards.length || typeof IntersectionObserver === "undefined") return;

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    cards.forEach(function (card) {
      observer.observe(card);
    });
  })();
</script>
