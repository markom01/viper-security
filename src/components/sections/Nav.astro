---
const { pageContent } = Astro.props;
const { brandName } = Astro.props;
import STRINGS from '../../config/strings';
const s = STRINGS;
const n = pageContent?.nav;
---
<div data-w-id="4c909013-ef6c-e80a-a8e9-5aa3de1b3bf1" data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar w-nav">
  <div class="content-wrapper">
    <div data-w-id="4c909013-ef6c-e80a-a8e9-5aa3de1b3bf3" class="navbar-wrapper" style="opacity: 1;">
      <a href="/" class="logo-link w-nav-brand w--current" aria-label={s.nav.homeAria}>
        <img src="/template_files/678ba669a9998141bea0c6a9_logo.svg" loading="eager" alt={n?.brand} class="brand-image" width="180" height="40" />
      </a>
      <nav role="navigation" class="nav-menu-wrapper w-nav-menu">
        <ul role="list" class="nav-menu-list w-list-unstyled">
          <li class="nav-list-item nav-list-brand">
            <a href="/" class="logo-link w-nav-brand w--current" aria-label={s.nav.homeAria}>
              <img src="/template_files/678ba669a9998141bea0c6a9_logo.svg" loading="eager" alt={n?.brand} class="brand-image" />
            </a>
          </li>
          <li class="nav-list-item"><a href="/" class="nav-link w--current">{n?.home}</a></li>
          <li class="nav-list-item"><a href="/#about" class="nav-link">{n?.about}</a></li>
          <li class="nav-list-item"><a href="/#services" class="nav-link">{n?.services}</a></li>
          <li class="nav-list-item"><a href="/#fleet" class="nav-link">{n?.fleet}</a></li>
          <li class="nav-list-item"><a href="/#how-it-works" class="nav-link">{n?.how_it_works}</a></li>
          <li class="nav-list-item"><a href="/#pricing" class="nav-link">{n?.pricing}</a></li>
          <li class="nav-list-item desktop-button">
            <a data-w-id="77fa09e7-63ce-cf39-8649-db69baef8b84" href="/#contact" class="primary-button small w-inline-block">
              <div class="button-text">{n?.contact}</div>
              <img src="/template_files/67596411f9729ddbe9caa4d1_right-arrow.svg" loading="eager" alt={s.icons.arrowAlt} class="button-arrow" />
            </a>
          </li>
          <li class="nav-list-item tablet-mobile-button">
            <a data-w-id="31b44076-9e9e-e074-a942-d52bc90dfd3a" href="/#contact" class="secondary-button w-inline-block">
              <div class="button-text">{n?.contact}</div>
              <img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt={s.icons.arrowAlt} class="button-arrow" />
            </a>
          </li>
        </ul>
        <div class="close-menu-button w-nav-button" style="-webkit-user-select: text;" aria-label={s.nav.menuAria} role="button" tabindex="0" aria-controls="w-nav-overlay-0" aria-haspopup="menu" aria-expanded="false">
          <div class="nav-close">
            <img src="/template_files/675987d262108fe13600ca80_cancel.svg" loading="eager" alt={s.nav.cancelAlt} />
          </div>
        </div>
      </nav>
      <div class="nav-buttons-wrapper">
        <div class="tablet-button">
          <a data-w-id="77fa09e7-63ce-cf39-8649-db69baef8b84" href="/#contact" class="primary-button small w-inline-block">
            <div class="button-text">{n?.contact}</div>
            <img src="/template_files/67596411f9729ddbe9caa4d1_right-arrow.svg" loading="eager" alt={s.icons.arrowAlt} class="button-arrow" />
          </a>
        </div>
        <div class="open-menu-button w-nav-button" style="-webkit-user-select: text;" aria-label={s.nav.menuAria} role="button" tabindex="0" aria-controls="w-nav-overlay-0" aria-haspopup="menu" aria-expanded="false">
          <div class="nav-open">
            <div class="menu-line"></div><div class="menu-line"></div><div class="menu-line"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="w-nav-overlay" data-wf-ignore="" id="w-nav-overlay-0"></div>
</div>
