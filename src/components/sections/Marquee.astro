---
const { pageContent } = Astro.props;
let html = `<section class="marquee-section"><div class="marquee-wrapper"><div class="marquee" style="transform: translate3d(-82.5344%, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; will-change: transform;"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"></div><div class="marquee" style="transform: translate3d(-82.5344%, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; will-change: transform;"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"><div class="marquee-text">__MARQUEE_TEXT__</div><img src="/template_files/675c2ab3bf36d6aa05ffff75_marquee-icon.svg" loading="eager" alt="Marquee Icon"></div></div></section>`;
html = html.replaceAll('__MARQUEE_TEXT__', pageContent?.marquee_text);
---
<Fragment set:html={html} />
