---
const { pageContent } = Astro.props;
const { subtitle, cta_text, tagline, hero_image } = Astro.props;
let html = `<section class="section home-hero-section"><div class="content-wrapper"><div class="hero-container"><div class="hero-text-wrapper"><div data-w-id="f361aa22-3d08-e663-a2af-349cf6e0b616" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-heading-wrapper"><h1 data-w-id="45d5705e-344f-13e7-4f65-4cf866f6096c">__HERO_TAGLINE__</h1></div><div data-w-id="18de8ef4-ecd4-7b4a-9536-a17067e5b87a" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-text-details"><p>__HERO_SUBTITLE__</p><div class="subheadline-wrapper"><div class="subheadline-line"></div><div class="subheadline">__HERO_CTA__</div></div></div></div><div data-w-id="92ed9f6f-c07a-52da-5245-ca6dc0a61ac3" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-content-wrapper"><div data-w-id="fc082705-03df-5327-1491-641af90188cc" style="opacity: 1;" class="hero-buttons-wrapper"><div class="hero-button-left"><a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#about" class="secondary-button small w-inline-block"><div class="button-text">__HERO_LEARN__</div><img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="Right Arrow Icon" class="button-arrow"></a></div><div class="hero-button-right"><a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#fleet" class="secondary-button small w-inline-block"><div class="button-text">__HERO_EXPLORE__</div><img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="Right Arrow Icon" class="button-arrow"></a></div></div><div data-w-id="41df484e-4b97-0be1-7e6f-f18e0a540a20" style="opacity: 1;" class="hero-image-wrapper"><img src="__HERO_IMAGE__" loading="eager" alt="Hero Image" class="hero-image" width="700" height="800"></div><div style="opacity:1;overflow:hidden;position:relative;border-top:none;" class="booking-form-wrapper"><div id="booking-form-mount"></div></div></div></div></div></div>__HERO_FORM_FIX__</section>`;
html = html.replace('__HERO_SUBTITLE__', subtitle);
html = html.replace('__HERO_CTA__', cta_text);
html = html.replace('__HERO_TAGLINE__', tagline);
html = html.replace('__HERO_LEARN__', pageContent?.hero?.learn_more);
html = html.replace('__HERO_EXPLORE__', pageContent?.hero?.explore_fleet);
html = html.replace('__FORM_NAME__', pageContent?.form?.name);
html = html.replace('__FORM_PHONE__', pageContent?.form?.phone);
html = html.replace('__FORM_DESTINATION__', pageContent?.form?.destination);
html = html.replace('__FORM_DATE__', pageContent?.form?.date);
html = html.replace('__FORM_SERVICE__', pageContent?.form?.service);
html = html.replace('__FORM_SUCCESS__', pageContent?.form?.success);
html = html.replace('__FORM_ERROR__', pageContent?.form?.error);
html = html.replace('__HERO_IMAGE__', hero_image);
html = html.replace('__HERO_FORM_FIX__', '<style>.booking-form-wrapper{overflow:hidden;position:relative;}.booking-form-wrapper::before{content:"";position:absolute;top:0;left:0;right:0;height:8px;background:var(--colors--amber);z-index:1;border-radius:24px 24px 0 0;border-top:none!important;}</style>');
---
<Fragment set:html={html} />
