ole="region" aria-label="Booking Form failure"><div>__FORM_ERROR__</div></div></div></div></div></div></div>__HERO_FORM_FIX__</section>`;
html = html.replace('__HERO_SUBTITLE__', subtitle);
html = html.replace('__HERO_CTA__', cta_text);
