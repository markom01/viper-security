---
const { pageContent } = Astro.props;
const { subtitle, cta_text, tagline, hero_image } = Astro.props;
let html = `<section class="section home-hero-section"><div class="content-wrapper"><div class="hero-container"><div class="hero-text-wrapper"><div data-w-id="f361aa22-3d08-e663-a2af-349cf6e0b616" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-heading-wrapper"><h1 data-w-id="45d5705e-344f-13e7-4f65-4cf866f6096c">__HERO_TAGLINE__</h1></div><div data-w-id="18de8ef4-ecd4-7b4a-9536-a17067e5b87a" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-text-details"><p>__HERO_SUBTITLE__</p><div class="subheadline-wrapper"><div class="subheadline-line"></div><div class="subheadline">__HERO_CTA__</div></div></div></div><div data-w-id="92ed9f6f-c07a-52da-5245-ca6dc0a61ac3" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-content-wrapper"><div data-w-id="fc082705-03df-5327-1491-641af90188cc" style="opacity: 1;" class="hero-buttons-wrapper"><div class="hero-button-left"><a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#about" class="secondary-button small w-inline-block"><div class="button-text">__HERO_LEARN__</div><img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="Right Arrow Icon" class="button-arrow"></a></div><div class="hero-button-right"><a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#fleet" class="secondary-button small w-inline-block"><div class="button-text">__HERO_EXPLORE__</div><img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="Right Arrow Icon" class="button-arrow"></a></div></div><div data-w-id="41df484e-4b97-0be1-7e6f-f18e0a540a20" style="opacity: 1;" class="hero-image-wrapper"><img src="__HERO_IMAGE__" loading="eager" alt="Hero Image" class="hero-image"></div><div data-w-id="d18e3e79-52f1-99d2-2448-3bb445032035" style="opacity: 1;" class="booking-form-wrapper"><div class="booking-form-block"><form id="wf-form-Booking-Form" name="Booking" method="POST" class="booking-form" data-netlify="true" aria-label="Booking Form"><input type="hidden" name="form-name" value="Booking"><div class="left-side-fields"><div class="booking-form-label-field"><label for="Full-Name" class="booking-form-label">__FORM_NAME__</label><input class="booking-form-field w-input" maxlength="256" name="Full-Name" data-name="Full Name" placeholder="John Doe" type="text" id="Full-Name" required=""></div><div class="booking-form-label-field"><label for="Phone" class="booking-form-label">__FORM_PHONE__</label><input class="booking-form-field w-input" maxlength="256" name="Phone" data-name="Phone" placeholder="+971 12 345 6789" type="tel" id="Phone" required=""></div><div class="booking-form-label-field"><label for="Pick-Up-Location" class="booking-form-label">__FORM_PICKUP__</label><input class="booking-form-field w-input" maxlength="256" name="Pick-Up-Location" data-name="Pick Up Location" placeholder="Palm Jumeirah" type="text" id="Pick-Up-Location" required=""></div></div><div class="right-side-fields"><div class="booking-form-label-field"><label for="Pick-Up-Date" class="booking-form-label">__FORM_DATE__</label><input class="booking-form-field w-input" maxlength="256" name="Pick-Up-Date" data-name="Pick Up Date" placeholder="Jan 10, 2025" type="text" id="Pick-Up-Date" required=""></div><div class="booking-form-label-field"><label for="Service" class="booking-form-label">__FORM_SERVICE__</label><select id="Service" name="Service" data-name="Service" required="" class="booking-form-field w-select"><option value="">Select one...</option><option value="Airport Services">Airport Services</option><option value="Limo Services">Limo Services</option><option value="Event Services">Event Services</option><option value="Group Services">Group Services</option><option value="Corporate Services">Corporate Services</option></select></div><div class="booking-button-wrapper"><input type="submit" data-wait="Please wait..." class="booking-form-button home-booking-form w-button" value="Book Now"></div></div></form><div class="booking-form-success w-form-done" tabindex="-1" role="region" aria-label="Booking Form success"><div>__FORM_SUCCESS__</div></div><div class="form-error-message w-form-fail" tabindex="-1" role="region" aria-label="Booking Form failure"><div>__FORM_ERROR__</div></div></div></div></div></div></div></section>`;
html = html.replace('__HERO_SUBTITLE__', subtitle);
html = html.replace('__HERO_CTA__', cta_text);
html = html.replace('__HERO_TAGLINE__', tagline);
html = html.replace('__HERO_LEARN__', pageContent?.hero?.learn_more);
html = html.replace('__HERO_EXPLORE__', pageContent?.hero?.explore_fleet);
html = html.replace('__FORM_NAME__', pageContent?.form?.name);
html = html.replace('__FORM_PHONE__', pageContent?.form?.phone);
html = html.replace('__FORM_PICKUP__', pageContent?.form?.pickup);
html = html.replace('__FORM_DATE__', pageContent?.form?.date);
html = html.replace('__FORM_SERVICE__', pageContent?.form?.service);
html = html.replace('__FORM_SUCCESS__', pageContent?.form?.success);
html = html.replace('__FORM_ERROR__', pageContent?.form?.error);
html = html.replace('__HERO_IMAGE__', hero_image);
---
<Fragment set:html={html} />
