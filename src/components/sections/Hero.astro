---
const { pageContent } = Astro.props;
const { subtitle, cta_text, tagline, hero_image } = Astro.props;
import STRINGS from '../../config/strings';
const s = STRINGS;
const h = pageContent?.hero;
const form = pageContent?.form;

const bd = pageContent?.booking_data;
const SCRIPT_DATA = {
  spain: bd?.spain || { label: '', services: [] },
  italy: bd?.italy || { label: '', services: [] },
  SS: form?.select_service,
  SR: form?.select_route,
  CL: form?.choose_location_first,
  CS: form?.choose_service_first,
};
---
<section class="section home-hero-section">
  <div class="content-wrapper">
    <div class="hero-container">
      <div class="hero-text-wrapper">
        <div data-w-id="f361aa22-3d08-e663-a2af-349cf6e0b616" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-heading-wrapper">
          <h1 data-w-id="45d5705e-344f-13e7-4f65-4cf866f6096c">{tagline}</h1>
        </div>
        <div data-w-id="18de8ef4-ecd4-7b4a-9536-a17067e5b87a" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-text-details">
          <p>{subtitle}</p>
          <div class="subheadline-wrapper">
            <div class="subheadline-line"></div>
            <div class="subheadline">{cta_text}</div>
          </div>
        </div>
      </div>
      <div data-w-id="92ed9f6f-c07a-52da-5245-ca6dc0a61ac3" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="hero-content-wrapper">
        <div data-w-id="fc082705-03df-5327-1491-641af90188cc" style="opacity: 1;" class="hero-buttons-wrapper">
          <div class="hero-button-left">
            <a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#about" class="secondary-button small w-inline-block">
              <div class="button-text">{h?.learn_more}</div>
              <img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt={s.icons.arrowAlt} class="button-arrow" />
            </a>
          </div>
          <div class="hero-button-right">
            <a data-w-id="4fa73ed9-0885-2043-799f-7bb694c2513b" href="/#fleet" class="secondary-button small w-inline-block">
              <div class="button-text">{h?.explore_fleet}</div>
              <img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt={s.icons.arrowAlt} class="button-arrow" />
            </a>
          </div>
        </div>
        <div data-w-id="41df484e-4b97-0be1-7e6f-f18e0a540a20" style="opacity: 1;" class="hero-image-wrapper">
          <img src={hero_image} loading="eager" alt={h?.image_alt} class="hero-image" width="700" height="800" />
        </div>
        <div style="opacity:1;overflow:hidden;position:relative;border-top:none;" class="booking-form-wrapper">
          <div style="position:absolute;top:0;left:0;right:0;height:8px;background:var(--colors--amber);z-index:1;border-radius:24px 24px 0 0;"></div>
          <div class="booking-form-block">
            <form name={s.hero.formName} method="POST" data-netlify="true" class="booking-form" aria-label={s.hero.bookingFormAria}>
              <input type="hidden" name="form-name" value={s.hero.formName} />
              <input name="bot-field" style="display:none" tabindex="-1" autocomplete="off" />
              <div class="left-side-fields">
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.name}</label>
                  <input class="booking-form-field w-input" name="Full-Name" placeholder={form?.name_placeholder} type="text" required />
                </div>
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.phone}</label>
                  <input class="booking-form-field w-input" name="Phone" placeholder={form?.phone_placeholder} type="tel" required />
                </div>
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.location}</label>
                  <select class="booking-form-field w-select" name="Location" id="form-location" required>
                    <option value="">{form?.select_location}</option>
                    <option value="spain">{bd?.spain?.label}</option>
                    <option value="italy">{bd?.italy?.label}</option>
                  </select>
                </div>
              </div>
              <div class="right-side-fields">
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.service}</label>
                  <select class="booking-form-field w-select" name="Service" id="form-service" required disabled>
                    <option value="">{form?.choose_location_first}</option>
                  </select>
                </div>
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.date}</label>
                  <input class="booking-form-field w-input" name="Pick-Up-Date" type="date" required />
                </div>
                <div class="booking-form-label-field">
                  <label class="booking-form-label">{form?.destination}</label>
                  <select class="booking-form-field w-select" name="Destination" id="form-destination" required disabled>
                    <option value="">{form?.choose_service_first}</option>
                  </select>
                </div>
                <div class="booking-button-wrapper">
                  <input type="submit" class="booking-form-button home-booking-form w-button" value={form?.book_now} />
                </div>
              </div>
            </form>
            <div class="booking-form-success w-form-done" role="status" style="display:none"><div>{form?.success}</div></div>
            <div class="form-error-message w-form-fail" role="alert" style="display:none"><div>{form?.error}</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script define:vars={{ data: SCRIPT_DATA }}>
(function(){
var d=data;
var R={spain:d.spain,italy:d.italy},SS=d.SS,SR=d.SR,CL=d.CL,CS=d.CS;
var L=document.getElementById('form-location'),S=document.getElementById('form-service'),D=document.getElementById('form-destination');
if(!L)return;
function uS(){var l=L.value,s=l&&R[l]?R[l].services:[];S.innerHTML='<option value="">'+(l?SS:CL)+'</option>';S.disabled=!l;
for(var i=0;i<s.length;i++){var o=document.createElement('option');o.value=s[i].name;o.textContent=s[i].name;S.appendChild(o)}uD()}
function uD(){var l=L.value,sn=S.value,rt=[];if(l&&sn&&R[l]){var sv=R[l].services;for(var i=0;i<sv.length;i++){if(sv[i].name===sn){rt=sv[i].routes;break}}}
D.innerHTML='<option value="">'+(sn?SR:CS)+'</option>';D.disabled=!sn;
for(var j=0;j<rt.length;j++){var r2=rt[j].route??rt[j];var o2=document.createElement('option');o2.value=r2;o2.textContent=r2;D.appendChild(o2)}}
L.addEventListener('change',uS);S.addEventListener('change',uD);
document.querySelector('.booking-form').addEventListener('submit',function(e){if(e.target.checkValidity()){document.querySelector('.booking-form-success').style.display='block';document.querySelector('.booking-form').style.display='none';}});
})();
</script>
