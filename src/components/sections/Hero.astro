html = html.replace('__FORM_PHONE__', pageContent?.form?.phone);
html = html.replace('__FORM_DESTINATION__', pageContent?.form?.destination);
html = html.replace('__FORM_DATE__', pageContent?.form?.date);
html = html.replace('__FORM_SERVICE__', pageContent?.form?.service);
html = html.replace('__FORM_SUCCESS__', pageContent?.form?.success);
html = html.replace('__FORM_ERROR__', pageContent?.form?.error);
html = html.replace('__HERO_IMAGE__', hero_image);
html = html.replace('__HERO_FORM_FIX__', '<style>.booking-form-wrapper{overflow:hidden;position:relative;}.booking-form-wrapper::before{content:"";position:absolute;top:0;left:0;right:0;height:8px;background:var(--colors--amber);z-index:1;border-radius:24px 24px 0 0;border-top:none!important;}</style>');
