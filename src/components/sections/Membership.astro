---
const { tiers, pageContent } = Astro.props;
import type { MembershipTier } from '../../types';
import STRINGS from '../../config/strings';
const s = STRINGS;
---
<section id="membership" class="section membership-section">
  <div class="content-wrapper">
    <div data-scroll-reveal class="steps-heading-wrapper">
      <div class="subheadline-wrapper">
        <div class="subheadline-line"></div>
        <div class="subheadline">{s.membership.title}</div>
      </div>
      <h2 class="steps-heading">{s.membership.heading}</h2>
    </div>
    <div data-scroll-reveal class="w-dyn-list">
      <div role="list" class="_3-column-collection w-dyn-items">
        {tiers?.map((t: MembershipTier) => (
          <div role="listitem" class="w-dyn-item" style="padding:8px;display:flex;">
            <div class={"booking-form-wrapper" + (t.is_featured ? " memb-featured-card" : "")} style="width:100%;display:flex;flex-direction:column;align-items:center;padding:0;">
              {t.is_featured ? <div class="memb-badge">{s.membership.badge}</div> : <div class="memb-badge-spacer"></div>}
              <div class="memb-card-body">
                <h3 class="booking-form-label" style="font-size:1rem;letter-spacing:2px;">{t.name}</h3>
                <div class="memb-price">{t.price}</div>
                <div class="memb-per-year">{s.membership.perYear}</div>
                <ul class="memb-benefits-list">
                  {t.benefits?.map((b: string) => (
                    <li class="memb-benefit-item">{b}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  :root{--colors--gold-bright:#c8a04c}
  [data-scroll-reveal]{opacity:0;transform:translateY(40px);transition:opacity 0.7s cubic-bezier(0.16,1,0.3,1),transform 0.7s cubic-bezier(0.16,1,0.3,1);}
  [data-scroll-reveal-visible]{opacity:1;transform:translateY(0);}
  @media(prefers-reduced-motion:reduce){[data-scroll-reveal]{opacity:1;transform:translateY(0);transition:none;}}
  .membership-section .booking-form-wrapper{overflow:hidden;position:relative;}.membership-section .booking-form-wrapper::before{content:"";position:absolute;top:0;left:0;right:0;height:8px;background:var(--colors--amber);z-index:1;border-radius:24px 24px 0 0;}.membership-section .booking-form-wrapper{border-top:none;}.membership-section .booking-form-wrapper{height:100%;}.membership-section .memb-featured-card{border-top-color:var(--colors--gold-bright);border-top-width:8px;}.membership-section .memb-badge{background:var(--colors--amber);color:#000;text-align:center;padding:10px 20px;font-size:1rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;width:100%;border-radius:0;margin-top:0;}.membership-section .memb-badge-spacer{height:38px;width:100%;}.membership-section .memb-card-body{display:flex;flex-direction:column;align-items:center;text-align:center;padding:20px 24px 24px;width:100%;}.membership-section .memb-price{font-size:2rem;color:var(--colors--gold);font-family:var(--font-families--accent-font);font-weight:600;line-height:1.1;margin:8px 0 2px;}.membership-section .memb-per-year{font-size:1rem;color:var(--colors--slate);margin-bottom:8px;}.membership-section .memb-benefits-list{list-style:none;padding:0;margin:8px 0 0;text-align:left;font-size:1rem;width:100%;}.membership-section .memb-benefit-item{padding:8px 12px;border-bottom:1px solid rgba(0,0,0,0.06);line-height:1.5;color:var(--colors--onyx);}.membership-section .memb-benefit-item:last-child{border-bottom:none;}.membership-section .memb-benefit-item:before{content:"✓";color:var(--colors--gold);margin-right:10px;font-weight:700;}
.membership-section .subheadline{color:var(--colors--gold-bright)}
.membership-section .subheadline-line{background-color:var(--colors--gold-bright)}
</style>
<script is:inline>
(function(){var e=document.querySelectorAll('[data-scroll-reveal]');if(!e.length)return;var o=new IntersectionObserver(function(n){n.forEach(function(n){n.isIntersecting&&(n.target.setAttribute('data-scroll-reveal-visible',''),o.unobserve(n.target))})},{threshold:.15,rootMargin:'0px 0px -50px 0px'});e.forEach(function(e){o.observe(e)})})();
</script>
