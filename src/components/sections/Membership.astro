---
const { tiers, pageContent } = Astro.props;
import STRINGS from '../../config/strings';
const s = STRINGS;
---
<section id="membership" class="section membership-section">
  <div class="content-wrapper">
    <div data-scroll-reveal class="steps-heading-wrapper">
      <div class="subheadline-wrapper">
        <div class="subheadline-line"></div>
        <div class="subheadline">{s.membership.title}</div>
      </div>
      <h2 class="steps-heading">{s.membership.heading}</h2>
    </div>
    <div data-scroll-reveal class="w-dyn-list">
      <div role="list" class="_3-column-collection w-dyn-items">
        {tiers?.map(t => (
          <div role="listitem" class="w-dyn-item" style="padding:8px;display:flex;">
            <div class={"booking-form-wrapper" + (t.is_featured ? " memb-featured-card" : "")} style="width:100%;display:flex;flex-direction:column;align-items:center;padding:0;">
              {t.is_featured ? <div class="memb-badge">{s.membership.badge}</div> : null}
              <div class="memb-card-body">
                <h3 class="booking-form-label" style="font-size:0.85rem;letter-spacing:2px;">{t.name}</h3>
                <div class="memb-price">{t.price}</div>
                <div class="memb-per-year">{s.membership.perYear}</div>
                <ul class="memb-benefits-list">
                  {t.benefits?.map(b => (
                    <li class="memb-benefit-item">{b}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
