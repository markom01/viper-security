---
const { pageContent } = Astro.props;
const { hourly } = Astro.props;
import STRINGS from '../../config/strings';
const s = STRINGS;
const bd = pageContent?.booking_data;

// Build 2 regional cards, each with service sections inside
const regionCards = [];

function buildRegionCard(services, regionLabel, regionShortLabel) {
  if (!services?.length) return null;
  const sections = [];
  // Each service type becomes a section
  services.forEach(svc => {
    const routes = svc.routes || [];
    if (routes.length) {
      sections.push({
        title: svc.name,
        routes: routes.map(r => ({
          label: r.route,
          price: r.price || '?',
        })),
      });
    }
  });
  // Add hourly rates as a section
  if (hourly?.rates?.length) {
    sections.push({
      title: s.pricing.hourlyHeading,
      routes: hourly.rates.map(r => ({ label: r.name, price: r.price })),
    });
  }
  if (sections.length) {
    return { name: regionLabel, shortLabel: regionShortLabel, sections };
  }
  return null;
}

const spainLabel = bd?.spain?.short_label || 'Marbella';
const italyLabel = bd?.italy?.short_label || 'Milano';

const marbellaCard = buildRegionCard(bd?.spain?.services, `VIPER Security — ${spainLabel}`, spainLabel);
const milanoCard = buildRegionCard(bd?.italy?.services, `VIPER Security — ${italyLabel}`, italyLabel);

const allCards = [marbellaCard, milanoCard].filter(Boolean);
---
<section id="pricing" class="section pricing-section">
  <div class="content-wrapper">
    <div data-scroll-reveal class="steps-heading-wrapper">
      <div class="subheadline-wrapper">
        <div class="subheadline-line"></div>
        <div class="subheadline">{s.pricing.title}</div>
      </div>
    </div>
    <div data-scroll-reveal class="pricing-grid">
      {allCards.map(card => (
        <div class="pricing-card-wrapper">
          <h2 class="pricing-card-heading">{card.name}</h2>
          <div class="booking-form-wrapper pricing-card">
            {card.sections.map((section, si) => (
              <div class="pricing-section-wrap">
                {si > 0 && <div class="pricing-section-divider"></div>}
                <h3 class="pricing-section-title">{section.title}</h3>
                {section.routes.map((item, ri) => (
                  <div class={"pricing-row" + (ri === 0 && si === 0 ? " pricing-row-first" : "")}>
                    <span class="pricing-service">{item.label}</span>
                    <span class="pricing-amount">{item.price}</span>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
