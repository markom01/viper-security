---
const { pageContent } = Astro.props;
const { marbella, milano } = Astro.props;
import type { ServiceOffering } from '../../types';
import STRINGS from '../../config/strings';
const s = STRINGS;
// Services are universal — both props carry the same data, pick whichever exists
const services = marbella || milano || [];
---
<section id="services" class="section services-section">
  <div class="content-wrapper">
    <div data-w-id="759830fb-8d10-d493-f200-61ee32fbd76c" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d; opacity: 1;" class="collection-heading-wrapper">
      <div class="services-subheadline">
        <div class="subheadline-wrapper">
          <div class="subheadline-line"></div>
          <h2 class="subheadline">{s.services.subheadline}</h2>
        </div>
      </div>
    </div>
    <div class="w-dyn-list">
      <div role="list" class="_4-column-collection w-dyn-items">
        {services.map((svc: ServiceOffering) => (
          <div role="listitem" class="service-collection-item w-dyn-item">
            <div data-w-id="736c1110-fb53-c783-1703-f2034df85288" class="service-card">
              <img src={svc.image} loading="lazy" alt={svc.title} class="service-listing-image" width="400" height="300" style="transform: translate3d(0px, 0px, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg); transform-style: preserve-3d;" />
              <div class="service-info-wrapper">
                <h3 class="service-listing-name">{svc.title}</h3>
                <div style="opacity: 0;" class="service-short-description">{svc.description}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
