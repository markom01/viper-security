---
const { pageContent } = Astro.props;
const { brandName, tagline, phoneItaly, phoneSpain } = Astro.props;
const f = pageContent?.footer;
const n = pageContent?.nav;
const fp = f?.description_prefix || '';
const ps = f?.phone_separator || '';
const footerDesc = fp + phoneItaly + ps + phoneSpain;
const copyrightText = f?.copyright;
const thisYear = new Date().getFullYear();
---
<footer class="footer" role="contentinfo">
  <div class="content-wrapper">
    <div class="footer-content-wrapper">
      <div data-w-id="d0f85d67-a980-65d6-511b-7dac5e2e60d0" class="footer-top" style="opacity: 1;">
        <div class="footer-heading-wrapper">
          <h2 class="footer-heading">{tagline}</h2>
        </div>
        <div class="footer-button-wrapper">
          <a data-w-id="31b44076-9e9e-e074-a942-d52bc90dfd3a" href="/#about" class="secondary-button w-inline-block">
            <div class="button-text">{f?.button}</div>
            <img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="" aria-hidden="true" class="button-arrow" />
          </a>
        </div>
      </div>
      <div data-w-id="d0f85d67-a980-65d6-511b-7dac5e2e60d8" class="footer-middle" style="opacity: 1;">
        <div class="footer-text-wrapper">
          <a href="/" class="logo-link w-nav-brand w--current">
            <img src="/template_files/678ba669a9998141bea0c6a9_logo.svg" loading="eager" alt={f?.logo_alt} class="brand-image" width="180" height="40" />
          </a>
          <p class="pure-text">{footerDesc}</p>
          <div class="social-links-wrapper">
            <a href="https://x.com/" target="_blank" class="social-link w-inline-block" aria-label={f?.social_x}>
              <img src="/template_files/676146330671d1a905c5ac9f_x-logo.svg" width="20" height="20" loading="eager" alt="" aria-hidden="true" />
            </a>
            <a href="https://www.tiktok.com/" target="_blank" class="social-link w-inline-block" aria-label={f?.social_tiktok}>
              <img src="/template_files/67614633ba459e6dd33b9860_tiktok-logo.svg" loading="eager" alt="" aria-hidden="true" />
            </a>
            <a href="https://www.instagram.com/" target="_blank" class="social-link w-inline-block" aria-label={f?.social_instagram}>
              <img src="/template_files/67614633f5d71118f6761e3e_instagram-logo.svg" loading="eager" alt="" aria-hidden="true" />
            </a>
            <a href="https://www.whatsapp.com/" target="_blank" class="social-link w-inline-block" aria-label={f?.social_whatsapp}>
              <img src="/template_files/67614633863a65d541abc011_whatsapp-logo.svg" loading="eager" alt="" aria-hidden="true" />
            </a>
          </div>
        </div>
        <div class="footer-links-wrapper">
          <div class="footer-links-column">
            <div class="footer-links-heading">{f?.pages}</div>
            <div class="footer-links">
              <a href="/" class="footer-link w--current">{n?.home || f?.home}</a>
              <a href="/#about" class="footer-link">{n?.about || f?.about}</a>
              <a href="/#services" class="footer-link">{n?.services || f?.services}</a>
              <a href="/#fleet" class="footer-link">{n?.fleet || f?.fleet}</a>
              <a href="/#how-it-works" class="footer-link">{n?.how_it_works || f?.how_it_works}</a>
              <a href="/#pricing" class="footer-link">{n?.pricing || f?.pricing}</a>
              <a href="/#contact" class="footer-link">{n?.contact || f?.contact}</a>
            </div>
          </div>
        </div>
      </div>
      <div data-w-id="6b3a195e-8f9a-3150-7a1b-0cbbe295f67f" class="footer-bottom" style="opacity: 1;">
        <div class="footer-legal">
          <div>{copyrightText}{thisYear} {brandName}</div>
        </div>
      </div>
    </div>
  </div>
</footer>
