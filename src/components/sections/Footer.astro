---
const { pageContent } = Astro.props;
const { brandName, tagline, phoneItaly, phoneSpain } = Astro.props;
let html = `<section class="footer"><div class="content-wrapper"><div class="footer-content-wrapper"><div data-w-id="d0f85d67-a980-65d6-511b-7dac5e2e60d0" class="footer-top" style="opacity: 1;"><div class="footer-heading-wrapper"><h2 class="footer-heading">__FOOTER_TAGLINE__</h2></div><div class="footer-button-wrapper"><a data-w-id="31b44076-9e9e-e074-a942-d52bc90dfd3a" href="/#about" class="secondary-button w-inline-block"><div class="button-text">__FOOTER_BUTTON__</div><img src="/template_files/6759814e92ecf4abb58bb0a7_right-arrow-pure.svg" loading="eager" alt="Right Arrow Icon" class="button-arrow"></a></div></div><div data-w-id="d0f85d67-a980-65d6-511b-7dac5e2e60d8" class="footer-middle" style="opacity: 1;"><div class="footer-text-wrapper"><a href="/"  class="logo-link w-nav-brand w--current"><img src="/template_files/678ba669a9998141bea0c6a9_logo.svg" loading="eager" alt="Logo" class="brand-image" width="180" height="40"></a><p class="pure-text">__FOOTER_DESC__</p><div class="social-links-wrapper"><a href="https://x.com/" target="_blank" class="social-link w-inline-block"><img src="/template_files/676146330671d1a905c5ac9f_x-logo.svg" width="20" height="20" loading="eager" alt="X Logo"></a><a href="https://www.tiktok.com/" target="_blank" class="social-link w-inline-block"><img src="/template_files/67614633ba459e6dd33b9860_tiktok-logo.svg" loading="eager" alt="TikTok Logo"></a><a href="https://www.instagram.com/" target="_blank" class="social-link w-inline-block"><img src="/template_files/67614633f5d71118f6761e3e_instagram-logo.svg" loading="eager" alt="Instagram Logo"></a><a href="https://www.whatsapp.com/" target="_blank" class="social-link w-inline-block"><img src="/template_files/67614633863a65d541abc011_whatsapp-logo.svg" loading="eager" alt="WhatsApp Logo"></a></div></div><div class="footer-links-wrapper"><div class="footer-links-column"><div class="footer-links-heading">__FOOTER_PAGES__</div><div class="footer-links"><a href="/"  class="footer-link w--current">__FOOTER_HOME__</a><a href="/#about" class="footer-link">__FOOTER_ABOUT__</a><a href="/#fleet" class="footer-link">__FOOTER_FLEET__</a><a href="/#services" class="footer-link">__FOOTER_SERVICES__</a><a href="/#contact" class="footer-link">__FOOTER_CONTACT__</a></div></div></div></div></div><div data-w-id="6b3a195e-8f9a-3150-7a1b-0cbbe295f67f" class="footer-bottom" style="opacity: 1;"><div class="footer-legal"><div>Copyright © 2025 __FOOTER_BRAND__</div><div>__FOOTER_POWERED__ <a href="https://webflow.com/" target="_blank">__FOOTER_WEBFLOW__</a>__FOOTER_DESIGNED__ <a href="https://am-templates.com/" target="_blank">__FOOTER_AM_TEMPLATES__</a></div></div></div></div></div></section>`;
html = html.replace('__FOOTER_TAGLINE__', tagline);
html = html.replace('__FOOTER_DESC__', 'Premium chauffeur services across Marbella, Milano, and beyond. ' + phoneItaly + ' / ' + phoneSpain);
html = html.replace('__FOOTER_BRAND__', brandName);
html = html.replace('__FOOTER_BUTTON__', pageContent?.footer?.button);
html = html.replace('__FOOTER_PAGES__', pageContent?.footer?.pages);
html = html.replace('__FOOTER_HOME__', pageContent?.footer?.home);
html = html.replace('__FOOTER_ABOUT__', pageContent?.footer?.about);
html = html.replace('__FOOTER_FLEET__', pageContent?.footer?.fleet);
html = html.replace('__FOOTER_SERVICES__', pageContent?.footer?.services);
html = html.replace('__FOOTER_CONTACT__', pageContent?.footer?.contact);
html = html.replace('__FOOTER_POWERED__', pageContent?.footer?.powered);
html = html.replace('__FOOTER_WEBFLOW__', pageContent?.footer?.webflow);
html = html.replace('__FOOTER_DESIGNED__', pageContent?.footer?.designed);
html = html.replace('__FOOTER_AM_TEMPLATES__', pageContent?.footer?.am_templates);
---
<Fragment set:html={html} />
