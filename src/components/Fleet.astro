---
// VIPER SECURITY — Fleet Section
// Single vehicle showcase: Mercedes-Benz S-Class 4MATIC AMG
---

<section id="fleet" class="relative py-20 lg:py-28 bg-dark-iron overflow-hidden">
  <!-- Subtle top-edge glow -->
  <div
    class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- ─── Section Header ─── -->
    <div class="flex items-center gap-4 mb-12 lg:mb-16">
      <span class="block w-8 h-px bg-gold/70" aria-hidden="true"></span>
      <h2
        class="font-heading text-gold text-sm lg:text-base uppercase tracking-[0.2em]"
      >
        Our Fleet
      </h2>
    </div>

    <!-- ─── Vehicle Showcase Card ─── -->
    <div
      class="fleet-card flex flex-col lg:flex-row bg-charcoal border-l border-gold/40"
    >
      <!-- ===== Image Side ===== -->
      <div class="lg:w-1/2 relative overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1549399542-7e3f8b79c341?w=800&q=80"
          alt="Mercedes-Benz S-Class 4MATIC AMG interior — luxury leather steering wheel and dashboard"
          class="fleet-image w-full h-full object-cover aspect-[4/3] lg:aspect-auto lg:min-h-[520px] transition-transform duration-700 ease-out"
          loading="lazy"
        />

        <!-- Hover gradient overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 transition-opacity duration-500 ease-out"
          aria-hidden="true"
        ></div>
      </div>

      <!-- ===== Details Side ===== -->
      <div class="lg:w-1/2 p-8 lg:p-12 xl:p-14 flex flex-col justify-center">
        <!-- Vehicle Name -->
        <h3
          class="font-heading text-white text-2xl md:text-3xl lg:text-4xl leading-snug mb-8"
        >
          Mercedes-Benz<br />
          <span class="text-gold">S-Class 4MATIC AMG</span>
        </h3>

        <!-- Features Grid -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3.5 mb-8"
        >
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Luxury leather interior</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Rear executive seating</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Climate control</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Privacy glass</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Wi‑Fi available upon request</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Complimentary bottled water</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Phone charging facilities</span
            >
          </div>
          <div class="flex items-center gap-3">
            <span
              class="block w-1.5 h-1.5 bg-gold rounded-full shrink-0 mt-px"
              aria-hidden="true"
            ></span>
            <span class="text-white/75 text-sm lg:text-base font-body"
              >Professional English‑speaking driver</span
            >
          </div>
        </div>

        <!-- Capacity -->
        <div
          class="flex flex-wrap items-center gap-x-2 text-ash text-sm font-body"
        >
          <span>Up to 3 passengers</span>
          <span class="text-white/20" aria-hidden="true">•</span>
          <span>3 large suitcases</span>
          <span class="text-white/20" aria-hidden="true">•</span>
          <span>2 carry‑on bags</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Image scale on hover ─── */
  .fleet-card:hover .fleet-image {
    transform: scale(1.05);
  }

  .fleet-card:hover .absolute.inset-0 {
    opacity: 1;
  }

  /* ─── Scroll-triggered fade-in animation ─── */
  @keyframes fleet-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fleet-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .fleet-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  (function () {
    const card = document.querySelector(".fleet-card");
    if (!card || typeof IntersectionObserver === "undefined") return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(card);
  })();
</script>
