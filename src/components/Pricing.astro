---

---

<section id="pricing" class="bg-black py-20">
  <div class="mx-auto max-w-[1200px] px-6">
    <!-- ─── Section Title ─── -->
    <h2 class="font-heading text-gold text-center text-4xl tracking-[0.15em] md:text-5xl">
      PRICING
    </h2>
    <div class="mx-auto mb-16 mt-4 h-px w-16 bg-gold/40"></div>

    <!-- ════════════════════════════════════════════ -->
    <!-- HOURLY CHAUFFEUR SERVICE                    -->
    <!-- ════════════════════════════════════════════ -->
    <div class="mb-24">
      <h3
        class="font-body text-white text-center text-base tracking-[0.12em] uppercase md:text-lg"
      >
        HOURLY CHAUFFEUR SERVICE
      </h3>
      <div class="mx-auto mt-2 mb-12 h-px w-12 bg-white/10"></div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <!-- 1 Hour -->
        <div class="border border-white/5 bg-dark-iron p-6 text-center transition-colors duration-300 hover:border-gold/30">
          <p class="font-body text-white text-sm mb-3 uppercase tracking-[0.1em]">1 Hour</p>
          <p class="font-heading text-gold text-3xl md:text-4xl leading-tight">€120</p>
          <p class="font-body text-ash/80 mt-2 text-[10px] uppercase tracking-[0.12em]">Chauffeur</p>
        </div>

        <!-- 2 Hours -->
        <div class="border border-white/5 bg-dark-iron p-6 text-center transition-colors duration-300 hover:border-gold/30">
          <p class="font-body text-white text-sm mb-3 uppercase tracking-[0.1em]">2 Hours</p>
          <p class="font-heading text-gold text-3xl md:text-4xl leading-tight">€220</p>
          <p class="font-body text-ash/80 mt-2 text-[10px] uppercase tracking-[0.12em]">Chauffeur</p>
        </div>

        <!-- 4 Hours -->
        <div class="border border-white/5 bg-dark-iron p-6 text-center transition-colors duration-300 hover:border-gold/30">
          <p class="font-body text-white text-sm mb-3 uppercase tracking-[0.1em]">4 Hours</p>
          <p class="font-heading text-gold text-3xl md:text-4xl leading-tight">€400</p>
          <p class="font-body text-ash/80 mt-2 text-[10px] uppercase tracking-[0.12em]">Chauffeur</p>
        </div>

        <!-- 8 Hours -->
        <div class="border border-white/5 bg-dark-iron p-6 text-center transition-colors duration-300 hover:border-gold/30">
          <p class="font-body text-white text-sm mb-3 uppercase tracking-[0.1em]">8 Hours</p>
          <p class="font-heading text-gold text-3xl md:text-4xl leading-tight">€700</p>
          <p class="font-body text-ash/80 mt-2 text-[10px] uppercase tracking-[0.12em]">Chauffeur</p>
        </div>

        <!-- Full Day (12 Hours) -->
        <div class="border border-gold/20 bg-dark-iron p-6 text-center transition-colors duration-300 hover:border-gold/50">
          <p class="font-body text-white text-sm mb-1 uppercase tracking-[0.1em]">Full Day</p>
          <p class="font-body text-ash/70 text-[10px] mb-3 uppercase tracking-[0.12em]">12 Hours</p>
          <p class="font-heading text-gold text-3xl md:text-4xl leading-tight">€950</p>
          <p class="font-body text-ash/80 mt-2 text-[10px] uppercase tracking-[0.12em]">Chauffeur</p>
        </div>
      </div>

      <p class="font-body text-ash/70 mt-8 text-center text-[11px] uppercase tracking-[0.15em]">
        Driver included.
      </p>
    </div>

    <!-- ════════════════════════════════════════════ -->
    <!-- AIRPORT TRANSFER PRICES                     -->
    <!-- ════════════════════════════════════════════ -->
    <div>
      <h3
        class="font-body text-white text-center text-base tracking-[0.12em] uppercase md:text-lg"
      >
        AIRPORT TRANSFER PRICES
      </h3>
      <div class="mx-auto mt-2 mb-12 h-px w-12 bg-white/10"></div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- ─── LEFT: Costa del Sol — Marbella ─── -->
        <div>
          <h4
            class="font-body text-white/60 mb-6 border-b border-white/10 pb-3 text-xs uppercase tracking-[0.15em]"
          >
            Costa del Sol — <span class="text-gold">Marbella</span>
          </h4>

          <div class="space-y-3">
            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Málaga Airport → Marbella</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€280</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Málaga Airport → Puerto Banús</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€300</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Málaga Airport → Estepona</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€350</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Málaga Airport → Sotogrande</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€380</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Gibraltar Airport → Marbella</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€400</span
              >
            </div>
          </div>
        </div>

        <!-- ─── RIGHT: Northern Italy & Alps — Milano ─── -->
        <div>
          <h4
            class="font-body text-white/60 mb-6 border-b border-white/10 pb-3 text-xs uppercase tracking-[0.15em]"
          >
            Northern Italy &amp; Alps — <span class="text-gold">Milano</span>
          </h4>

          <div class="space-y-3">
            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Malpensa Airport → Milano</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€200</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Milano Airport → Lugano</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€300</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Bergamo Airport → St. Moritz</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€350</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Malpensa Airport → Monaco</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€500</span
              >
            </div>

            <div
              class="flex items-center justify-between border border-white/5 bg-dark-iron px-5 py-4 transition-colors duration-300 hover:border-gold/20"
            >
              <span class="font-body text-white text-sm">Milano Airport → Zurich</span>
              <span class="font-heading text-gold text-base"
                ><span class="font-body text-ash/80 text-[10px]">From </span>€600</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
