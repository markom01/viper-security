---
import { getCollection } from 'astro:content';

const [entry] = await getCollection('faq');
const questions = entry?.data?.questions || [];
---

<section id="faq" class="bg-black py-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="font-heading text-gold text-4xl md:text-5xl tracking-[0.05em]">FREQUENTLY ASKED QUESTIONS</h2>
      <div class="w-16 h-px bg-gold/40 mx-auto mt-5"></div>
    </div>

    <div class="space-y-3">
      {questions.map((item) => (
        <details class="group border border-white/10 bg-dark-iron px-5 py-4">
          <summary class="list-none cursor-pointer flex items-center justify-between gap-4">
            <span class="text-white text-sm sm:text-base  font-body">{item.q}</span>
            <span class="text-gold text-lg leading-none transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="text-smoke/70 text-sm leading-relaxed mt-3 pr-8 text-light-on-dark max-w-prose">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
