          <ul class="space-y-2">
            <li class="flex items-start gap-3 text-sm leading-relaxed">
              <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
              <span class="text-smoke/70">
                <span class="text-white/90 font-medium">Milano Linate / Malpensa / Bergamo</span> &rarr;
