---
// Services.astro — VIPER SECURITY Services Section
---


<section id="services" class="py-20 bg-black">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Section Title -->
    <div class="text-center mb-16 lg:mb-20">
      <span class="text-ash text-xs uppercase tracking-[0.25em] font-body font-light">
        Premium Coverage Areas
      </span>
      <h2 class="font-heading text-gold text-4xl md:text-5xl lg:text-6xl mt-4 mb-5 tracking-[0.08em]">
        OUR SERVICES
      </h2>
      <div class="w-16 h-px bg-gold/60 mx-auto"></div>
    </div>

    <!-- Two-Column Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16">
      <!-- ========== LEFT COLUMN — Costa del Sol — Marbella ========== -->
      <div>
        <!-- Location Heading -->
        <div class="border-l-[3px] border-gold pl-5 mb-10">
          <h3 class="font-heading text-2xl md:text-3xl text-white leading-tight">
            Costa del Sol
          </h3>
          <p class="text-gold text-xs uppercase tracking-[0.2em] font-body font-light mt-1.5">
            Marbella
          </p>
        </div>

        <!-- 1 — Airport Transfers -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 mb-4 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
          <h4 class="text-gold font-heading text-lg mb-3 flex items-center gap-2.5">
            <span class="text-base leading-none" aria-hidden="true">&#9992;</span>
            <span>Airport Transfers</span>
          </h4>
          <ul class="space-y-1.5">
            <li class="flex items-start gap-3 text-sm leading-relaxed">
              <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
              <span class="text-smoke/70">
                <span class="text-white/90 font-medium">M&aacute;laga</span> &rarr; Marbella, Puerto Ban&uacute;s, Estepona, Sotogrande, Gibraltar
              </span>
            </li>
          </ul>
        </div>

        <!-- 2 — VIP Villa Transfers -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 mb-4 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
          <h4 class="text-gold font-heading text-lg mb-3 flex items-center gap-2.5">
            <span class="text-base leading-none" aria-hidden="true">&#10070;</span>
            <span>VIP Villa Transfers</span>
          </h4>
          <p class="text-smoke/70 text-sm leading-relaxed">
            Luxury transportation between villas, hotels, beach clubs and restaurants.
          </p>
        </div>

        <!-- 3 — Yacht Transfers -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 mb-4 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
          <h4 class="text-gold font-heading text-lg mb-3 flex items-center gap-2.5">
            <span class="text-base leading-none" aria-hidden="true">&#9973;</span>
            <span>Yacht Transfers</span>
          </h4>
          <ul class="space-y-1.5">
            <li class="flex items-start gap-3 text-sm leading-relaxed">
              <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
              <span class="text-smoke/70">Puerto Ban&uacute;s, Marbella Marina, Estepona Marina, Sotogrande Marina</span>
            </li>
          </ul>
        </div>

        <!-- 4 — Business & Corporate -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 mb-4 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
          <h4 class="text-gold font-heading text-lg mb-3 flex items-center gap-2.5">
            <span class="text-base leading-none" aria-hidden="true">&#9632;</span>
            <span>Business &amp; Corporate</span>
          </h4>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5">
            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Meetings
            </li>
            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Conferences
            </li>
            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Corporate events
            </li>
            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Business delegations
            </li>
          </ul>
        </div>

        <!-- 5 — Nightlife & VIP Club -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
