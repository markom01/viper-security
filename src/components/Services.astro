        </div>

        <!-- 5 — Nightlife & VIP Club -->
        <div class="bg-charcoal/50 backdrop-blur-sm border border-white/[0.06] rounded-xl p-5 transition-all duration-300 hover:border-gold/20 hover:bg-charcoal/70">
          <h4 class="text-gold font-heading text-lg mb-3 flex items-center gap-2.5">
            <span class="text-base leading-none" aria-hidden="true">&#10025;</span>
