---
import { getCollection } from 'astro:content';
import ServiceCard from './ServiceCard.astro';

const [marbella] = await getCollection('services-marbella');
const [milano] = await getCollection('services-milano');

// Split location_name like "Costa del Sol — Marbella" into primary + subtitle
const splitName = (name: string) => {
  const parts = name.split(/ [\u2014\-] /);
  return { primary: parts[0] || name, secondary: parts[1] || '' };
};

const marbellaLoc = splitName(marbella?.data?.location_name || 'Costa del Sol \u2014 Marbella');
const milanoLoc = splitName(milano?.data?.location_name || 'Northern Italy & Alps - Milano');
---


<section id="services" class="py-20 bg-black">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-16 lg:mb-20">
      <h2 class="font-heading text-gold text-4xl md:text-5xl lg:text-6xl mb-5 tracking-[0.05em]">
        OUR SERVICES
      </h2>
      <div class="w-16 h-px bg-gold/60 mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16">
      <!-- LEFT COLUMN — Costa del Sol — Marbella -->
      <div>
        <div class="mb-10">
          <h3 class="font-heading text-2xl md:text-3xl text-white leading-tight">
            {marbellaLoc.primary}
          </h3>
          <p class="text-gold text-xs font-body mt-1.5">
            {marbellaLoc.secondary}
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <ServiceCard icon="&#9992;" title="Airport Transfers">
            <ul class="space-y-1.5 max-w-prose">
              {marbella?.data?.airport_routes?.map((route) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
                  <span class="text-smoke/70">{route}</span>
                </li>
              ))}
            </ul>
          </ServiceCard>

          <ServiceCard icon="&#10070;" title="VIP Villa Transfers">
            <p class="text-smoke/70 text-sm leading-relaxed max-w-prose">
              {marbella?.data?.villa_transfers || 'Luxury transportation between villas, hotels, beach clubs and restaurants.'}
            </p>
          </ServiceCard>

          <ServiceCard icon="&#9973;" title="Yacht Transfers">
            <ul class="space-y-1.5 max-w-prose">
              {marbella?.data?.yacht_marinas?.map((marina) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
                  <span class="text-smoke/70">{marina}</span>
                </li>
              ))}
            </ul>
          </ServiceCard>

          <ServiceCard icon="&#9632;" title="Business & Corporate">
            <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5">
              {marbella?.data?.business_services?.map((service) => (
                <li class="flex items-center gap-2.5 text-sm text-smoke/70">
                  <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
                  {service}
                </li>
              ))}
            </ul>
          </ServiceCard>

          <ServiceCard icon="&#10025;" title="Nightlife & VIP Club">
            <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 mb-3">
              {marbella?.data?.nightlife_venues?.map((venue) => (
                <li class="flex items-center gap-2.5 text-sm text-smoke/70">
                  <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
                  {venue}
                </li>
              ))}
            </ul>
            <p class="text-gold text-xs italic font-light">
              Available with waiting service.
            </p>
          </ServiceCard>
        </div>
      </div>

      <!-- RIGHT COLUMN — Northern Italy & Alps — Milano -->
      <div>
        <div class="mb-10">
          <h3 class="font-heading text-2xl md:text-3xl text-white leading-tight">
            {milanoLoc.primary}
          </h3>
          <p class="text-gold text-xs font-body mt-1.5">
            {milanoLoc.secondary}
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <ServiceCard icon="&#9992;" title="Airport Transfers">
            <ul class="space-y-1.5 max-w-prose">
              {milano?.data?.airport_routes?.map((route) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <span class="text-gold/60 mt-0.5 shrink-0" aria-hidden="true">&#8212;</span>
                  <span class="text-smoke/70">{route}</span>
                </li>
              ))}
            </ul>
          </ServiceCard>

          <ServiceCard icon="&#10070;" title="VIP Villa Transfers">
            <p class="text-smoke/70 text-sm leading-relaxed max-w-prose">
              {milano?.data?.villa_transfers || 'Luxury transportation between villas, hotels, beach clubs and restaurants.'}
            </p>
          </ServiceCard>

          <ServiceCard icon="&#9973;" title="Yacht Transfers">
            <p class="text-smoke/70 text-sm leading-relaxed max-w-prose">
              {milano?.data?.yacht_transfers_desc || 'Private transportation.'}
            </p>
          </ServiceCard>

          <ServiceCard icon="&#9632;" title="Business & Corporate">
            <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5">
              {milano?.data?.business_services?.map((service) => (
                <li class="flex items-center gap-2.5 text-sm text-smoke/70">
                  <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
                  {service}
                </li>
              ))}
            </ul>
          </ServiceCard>

          <ServiceCard icon="&#10025;" title="Nightlife & VIP Club">
            <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 mb-3">
              {milano?.data?.nightlife_venues?.map((venue) => (
                <li class="flex items-center gap-2.5 text-sm text-smoke/70">
                  <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
                  {venue}
                </li>
              ))}
            </ul>
            <p class="text-gold text-xs italic font-light">
              Available with waiting service.
            </p>
          </ServiceCard>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  #services .rounded-xl {
    will-change: transform, border-color, background-color;
  }
</style>
