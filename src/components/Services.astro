            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Nightclubs
            </li>
            <li class="flex items-center gap-2.5 text-sm text-smoke/70">
              <span class="w-1 h-1 rounded-full bg-gold/60 shrink-0" aria-hidden="true"></span>
              Private events
            </li>
          </ul>
          <p class="text-gold/80 text-xs italic font-light">
            Available with waiting service.
          </p>
        </div>
      </div>

      <!-- ========== RIGHT COLUMN — Northern Italy & Alps — Milano ========== -->
      <div>
        <!-- Location Heading -->
        <div class="border-l-[3px] border-gold pl-5 mb-10">
          <h3 class="font-heading text-2xl md:text-3xl text-white leading-tight">
